    - wr_data[1] ( PIN wr_data[1] ) ( _182_ A1 ) ( _135_ A0 ) + USE SIGNAL ;
    - wr_data[2] ( PIN wr_data[2] ) ( _183_ A1 ) ( _136_ A0 ) + USE SIGNAL ;
    - wr_data[3] ( PIN wr_data[3] ) ( _184_ A1 ) ( _137_ A0 ) + USE SIGNAL ;
    - wr_data[4] ( PIN wr_data[4] ) ( _185_ A1 ) ( _138_ A0 ) + USE SIGNAL ;
    - wr_data[5] ( PIN wr_data[5] ) ( _186_ A1 ) ( _139_ A0 ) + USE SIGNAL ;
