{
  "top_module": "sram_mbist_demo_controller",
  "soc_mode": false,
  "clock_names": [
    "clk"
  ],
  "reset_signals": [
    {
      "name": "reset_n",
      "active_low": true,
      "async": false
    }
  ],
  "ports": [
    {
      "name": "clk",
      "direction": "input",
      "width_expr": "1"
    },
    {
      "name": "reset_n",
      "direction": "input",
      "width_expr": "1"
    },
    {
      "name": "wr_en",
      "direction": "input",
      "width_expr": "1"
    },
    {
      "name": "wr_addr",
      "direction": "input",
      "width_expr": "8"
    },
    {
      "name": "wr_data",
      "direction": "input",
      "width_expr": "32"
    },
    {
      "name": "rd_en",
      "direction": "input",
      "width_expr": "1"
    },
    {
      "name": "rd_addr",
      "direction": "input",
      "width_expr": "8"
    },
    {
      "name": "bist_start",
      "direction": "input",
      "width_expr": "1"
    },
    {
      "name": "rd_data",
      "direction": "output",
      "width_expr": "32"
    },
    {
      "name": "ready",
      "direction": "output",
      "width_expr": "1"
    },
    {
      "name": "bist_done",
      "direction": "output",
      "width_expr": "1"
    },
    {
      "name": "bist_fail",
      "direction": "output",
      "width_expr": "1"
    },
    {
      "name": "irq",
      "direction": "output",
      "width_expr": "1"
    }
  ]
}