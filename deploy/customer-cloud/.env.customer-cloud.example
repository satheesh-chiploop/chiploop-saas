CHIPLOOP_DEPLOYMENT_MODE=customer_cloud
CHIPLOOP_PUBLIC_URL=https://chiploop.customer.example
CHIPLOOP_BACKEND_URL=http://backend:8000
CHIPLOOP_TOOL_PROFILE_PATH=/etc/chiploop/tool_profile.json
CHIPLOOP_MODEL_PROFILE_PATH=/etc/chiploop/model_profile.json
CHIPLOOP_ARTIFACT_POLICY=customer_cloud_storage
CHIPLOOP_PRIVATE_ARTIFACT_ROOT=/var/lib/chiploop/artifacts
CHIPLOOP_LICENSE_MODE=customer_cloud
CHIPLOOP_LICENSE_KEY=

# Customer-managed database/storage/auth.
CHIPLOOP_DATABASE_PROVIDER=supabase
CHIPLOOP_STORAGE_PROVIDER=supabase
CHIPLOOP_AUTH_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alternative customer cloud combination:
# CHIPLOOP_DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://chiploop:password@postgres:5432/chiploop
# CHIPLOOP_STORAGE_PROVIDER=s3
# CHIPLOOP_STORAGE_BUCKET=chiploop-artifacts
# CHIPLOOP_STORAGE_PREFIX=prod
# CHIPLOOP_AUTH_PROVIDER=oidc
# CHIPLOOP_FRONTEND_PLATFORM_PROVIDER=backend_platform_api
# NEXT_PUBLIC_CHIPLOOP_PLATFORM_PROVIDER=backend
# CHIPLOOP_OIDC_ISSUER=https://identity.customer.example
# CHIPLOOP_OIDC_CLIENT_ID=chiploop
# CHIPLOOP_OIDC_CLIENT_SECRET=
# CHIPLOOP_OIDC_AUTHORIZATION_ENDPOINT=https://identity.customer.example/authorize
# CHIPLOOP_OIDC_TOKEN_ENDPOINT=https://identity.customer.example/token
# CHIPLOOP_OIDC_SCOPE=openid profile email
# For Azure Blob instead of S3:
# CHIPLOOP_STORAGE_PROVIDER=azure_blob
# AZURE_STORAGE_CONNECTION_STRING=

# Azure OpenAI or AWS Bedrock.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AWS_REGION=us-east-1
AWS_PROFILE=

# EDA licenses.
SNPSLMD_LICENSE_FILE=
CDS_LIC_FILE=
LM_LICENSE_FILE=
