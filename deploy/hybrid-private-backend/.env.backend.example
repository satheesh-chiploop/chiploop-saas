# Use a release tag or digest supplied by ChipLoop. Do not deploy "latest".
CHIPLOOP_IMAGE_TAG=hybrid-backend-v1.0.0
CHIPLOOP_BACKEND_PORT=8000
CHIPLOOP_DEPLOYMENT_MODE=hybrid_private_backend
CHIPLOOP_LICENSE_MODE=hybrid_private_backend
CHIPLOOP_LICENSE_KEY=replace-with-customer-license-key

# ChipLoop-hosted Supabase. ChipLoop provisions customer-scoped credentials.
SUPABASE_URL=https://replace-with-chiploop-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-customer-scoped-service-key
SUPABASE_JWT_SECRET=replace-with-jwt-secret
ARTIFACT_BUCKET_NAME=artifacts

# The hosted customer frontend must be the only browser origin allowed here.
CHIPLOOP_ALLOWED_ORIGINS=https://customer-name.getchiploop.com

# Customer-owned tool and model profiles.
CHIPLOOP_TOOL_PROFILE_PATH=/etc/chiploop/tool_profile.json
CHIPLOOP_MODEL_PROFILE_PATH=/etc/chiploop/model_profile.json
CHIPLOOP_ARTIFACT_POLICY=full_sync
CHIPLOOP_PRIVATE_ARTIFACT_ROOT=/var/lib/chiploop/artifacts

# Customer-managed model credentials. Set only the providers used by model_profile.json.
# Use byok for customer-paid model accounts, or chiploop_managed for ChipLoop AI-credit billing.
CHIPLOOP_AI_BILLING_MODE=byok
CHIPLOOP_MODEL_KEY_OWNER=customer
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
ANTHROPIC_API_KEY=
AWS_REGION=

# Customer-managed commercial EDA licenses.
SNPSLMD_LICENSE_FILE=27000@license-server
CDS_LIC_FILE=5280@license-server
LM_LICENSE_FILE=27000@license-server
