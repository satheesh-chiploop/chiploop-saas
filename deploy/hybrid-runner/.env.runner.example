CHIPLOOP_MODE=hybrid_runner
CHIPLOOP_RUNNER_ID=customer-runner-1
CHIPLOOP_RUNNER_TOKEN=replace-with-issued-runner-token
CHIPLOOP_CONTROL_PLANE_URL=https://api.getchiploop.com
CHIPLOOP_TOOL_PROFILE_PATH=/etc/chiploop/tool_profile.json
CHIPLOOP_MODEL_PROFILE_PATH=/etc/chiploop/model_profile.json
CHIPLOOP_ARTIFACT_POLICY=summary_only

# Commercial EDA licenses remain customer-managed.
SNPSLMD_LICENSE_FILE=27000@license-server
CDS_LIC_FILE=5280@license-server
LM_LICENSE_FILE=27000@license-server

# Optional customer-owned model keys for private runner-side LLM execution.
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AWS_REGION=

