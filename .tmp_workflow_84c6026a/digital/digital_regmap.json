  "software_driver_intent": {
    "init_sequence": [
      "Write CONTROL with ENABLE=1 and IRQ_ENABLE as desired; keep SOFT_RESET=0 in normal operation.",
      "Optionally write MEM_ADDR and MEM_WDATA defaults for the first transaction.",
      "If needed, issue a CONTROL.SOFT_RESET pulse by writing bit 1 high for one cycle, then write it back low."
    ],
    "polling_sequence": [
      "Poll STATUS.ready for controller availability.",
      "After issuing MEM_CONTROL.MEM_READ, poll or delay one cycle as needed, then read MEM_RDATA.",
      "Poll BIST_STATUS.done/fail/running to observe test progress and outcome.",
      "Read IRQ_STATUS to determine which BIST result latched the interrupt."
    ],
    "irq_sequence": [
      "Enable IRQ generation by setting CONTROL.IRQ_ENABLE.",
      "Service the interrupt by reading IRQ_STATUS and then clearing the indicated bits with IRQ_CLEAR write-one-to-clear.",
      "If the BIST result should be re-armed, write BIST_CONTROL.CLEAR_RESULT=1 to clear latched BIST result state, then deassert it."
    ]
  },
