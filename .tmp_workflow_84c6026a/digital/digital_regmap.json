        "name": "bist_done",
        "description": "Asserted when BIST completion is latched and IRQ_ENABLE is set."
      },
      {
        "name": "bist_fail",
        "description": "Asserted when BIST failure is latched and IRQ_ENABLE is set."
      }
    ]
