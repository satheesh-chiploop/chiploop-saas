    "CHIPLOOP_OIDC_CLIENT_ID",
    "CHIPLOOP_FRONTEND_PLATFORM_PROVIDER",
    "NEXT_PUBLIC_CHIPLOOP_PLATFORM_PROVIDER"
  ]
}
