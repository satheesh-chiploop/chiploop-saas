{
  "profile_id": "chiploop_saas_default",
  "runner": "local_saas",
  "artifact_policy": "full_sync",
  "runtime": {
    "python": {
      "executable": "/root/chiploop-backend/venv/bin/python"
    },
    "pip": {
      "executable": "/root/chiploop-backend/venv/bin/pip"
    },
    "cocotb_config": {
      "executable": "/root/chiploop-backend/venv/bin/cocotb-config"
    },
    "pytest": {
      "executable": "/root/chiploop-backend/venv/bin/pytest"
    },
    "python3": {
      "executable": "/root/chiploop-backend/venv/bin/python3"
    }
  },
  "tools": {
    "iverilog": {
      "executable": "/usr/bin/iverilog"
    },
    "vvp": {
      "executable": "/usr/bin/vvp"
    },
    "verilator": {
      "executable": "/usr/local/bin/verilator"
    },
    "verilator_coverage": {
      "executable": "/usr/local/bin/verilator_coverage"
    },
    "yosys": {
      "executable": "/usr/bin/yosys"
    },
    "sby": {
      "executable": "/usr/local/bin/sby"
    },
    "z3": {
      "executable": "/usr/bin/z3"
    },
    "boolector": {
      "executable": "/usr/bin/boolector"
    },
    "gem5_x86": {
      "executable": "/opt/gem5/build/X86/gem5.opt"
    },
    "gem5_riscv": {
      "executable": "/opt/gem5/build/RISCV/gem5.opt"
    },
    "make": {
      "executable": "/usr/bin/make"
    },
    "cargo": {
      "executable": "/root/.cargo/bin/cargo"
    },
    "rustc": {
      "executable": "/root/.cargo/bin/rustc"
    },
    "llvm_cov": {
      "executable": "llvm-cov"
    },
    "llvm_profdata": {
      "executable": "llvm-profdata"
    },
    "gcov": {
      "executable": "gcov"
    },
    "git": {
      "executable": "/usr/bin/git"
    },
    "bash": {
      "executable": "/bin/bash"
    },
    "scons": {
      "executable": "/usr/bin/scons"
    },
    "gcc": {
      "executable": "/usr/bin/gcc"
    },
    "ngspice": {
      "executable": "/usr/bin/ngspice"
    },
    "riscv64_linux_gnu_gcc": {
      "executable": "riscv64-linux-gnu-gcc"
    },
    "riscv64_unknown_elf_gcc": {
      "executable": "riscv64-unknown-elf-gcc"
    },
    "x86_64_linux_gnu_gcc": {
      "executable": "x86_64-linux-gnu-gcc"
    }
  },
  "env": {
    "PATH": {
      "prepend": [
        "/root/chiploop-backend/venv/bin",
        "/usr/local/bin"
      ]
    }
  }
}
