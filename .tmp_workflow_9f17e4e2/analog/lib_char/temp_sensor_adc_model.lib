library (temp_sensor_adc_model_lib) {
  delay_model : table_lookup ;
  time_unit : "1ns" ;
  voltage_unit : "1V" ;
  current_unit : "1mA" ;
  capacitive_load_unit(1,pf) ;
  leakage_power_unit : "1nW" ;
  input_threshold_pct_rise : 50.0 ;
  input_threshold_pct_fall : 50.0 ;
  output_threshold_pct_rise : 50.0 ;
  output_threshold_pct_fall : 50.0 ;
  slew_lower_threshold_pct_rise : 20.0 ;
  slew_upper_threshold_pct_rise : 80.0 ;
  slew_lower_threshold_pct_fall : 20.0 ;
  slew_upper_threshold_pct_fall : 80.0 ;

  lu_table_template (delay_template_1x1) {
    variable_1 : input_net_transition ;
    variable_2 : total_output_net_capacitance ;
    index_1 ("0.100") ;
    index_2 ("0.100") ;
  }

  lu_table_template (constraint_template_1x1) {
    variable_1 : related_pin_transition ;
    variable_2 : constrained_pin_transition ;
    index_1 ("0.100") ;
    index_2 ("0.100") ;
  }

  type (adc_code_bus_t) {
    base_type : array ;
    data_type : bit ;
    bit_width : 12 ;
    bit_from : 11 ;
    bit_to : 0 ;
    downto : true ;
  }

  type (sensor_temp_celsius_bus_t) {
    base_type : array ;
    data_type : bit ;
    bit_width : 16 ;
    bit_from : 15 ;
    bit_to : 0 ;
    downto : true ;
  }

  cell (temp_sensor_adc_model) {
    area : 10000 ;

    pg_pin (VPWR) {
      pg_type : primary_power ;
      voltage_name : VPWR ;
    }

    pg_pin (VGND) {
      pg_type : primary_ground ;
      voltage_name : VGND ;
    }

    pin (VGND) {
      direction : inout ;
    }

    pin (VPWR) {
      direction : inout ;
    }

    bus (adc_code) {
      bus_type : adc_code_bus_t ;
      direction : output ;
      pin ("adc_code[0]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[1]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[2]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[3]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[4]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[5]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[6]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[7]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[8]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[9]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[10]") {
        direction : output ;
        function : "1" ;
      }
      pin ("adc_code[11]") {
        direction : output ;
        function : "1" ;
      }
    }

    pin (adc_valid) {
      direction : output ;
    }

    pin (avdd) {
      direction : inout ;
    }

    pin (avss) {
      direction : inout ;
    }

    pin (sample_req) {
      direction : input ;
    }

    bus (sensor_temp_celsius) {
      bus_type : sensor_temp_celsius_bus_t ;
      direction : input ;
      pin ("sensor_temp_celsius[0]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[1]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[2]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[3]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[4]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[5]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[6]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[7]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[8]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[9]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[10]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[11]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[12]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[13]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[14]") {
        direction : input ;
      }
      pin ("sensor_temp_celsius[15]") {
        direction : input ;
      }
    }

  }
}
